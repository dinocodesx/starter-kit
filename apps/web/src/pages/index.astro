---
import { auth } from "../lib/auth";
import Layout from "../layouts/Layout.astro";
import { AuthPanel } from "../components/auth-panel";
import { Button } from "@repo/ui/button";
import { Card } from "@repo/ui/card";

const session = await auth.api.getSession({
  headers: Astro.request.headers,
});

const sessionSummary = session
  ? {
      user: {
        name: session.user.name ?? null,
        email: session.user.email,
        image: session.user.image ?? null,
      },
    }
  : null;
---

<Layout title="Auth, email, and Prisma foundation">
  <main class="mx-auto flex min-h-screen w-full max-w-6xl items-center px-6 py-12 sm:px-10">
    <div class="grid w-full gap-10 lg:grid-cols-[1.15fr_0.85fr]">
      <section class="max-w-2xl">
        <p class="inline-flex items-center rounded-full border border-black/10 bg-white/70 px-4 py-2 text-xs font-semibold uppercase tracking-[0.28em] text-stone-700 backdrop-blur">
          Monorepo foundation
        </p>
        <h1 class="mt-8 text-5xl font-semibold tracking-tight text-stone-950 sm:text-6xl">
          Google auth, Resend email, and Prisma are now wired together.
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-8 text-stone-600">
          This Astro app now shares auth state, database persistence, and transactional
          email infrastructure with the rest of the workspace through reusable packages.
        </p>

        <div class="mt-8">
          <Button client:load appName="Web">UI Library Button</Button>
        </div>

        <div class="mt-10 grid gap-4 sm:grid-cols-3">
          <Card title="Auth" href="https://better-auth.com">
            Better Auth + Google OAuth
          </Card>
          <Card title="Database" href="https://prisma.io">
            Prisma + PostgreSQL
          </Card>
          <Card title="Email" href="https://resend.com">
            Resend delivery log
          </Card>
        </div>
      </section>

      <div class="lg:pt-8">
        <AuthPanel client:load session={sessionSummary} />
      </div>
    </div>
  </main>
</Layout>
