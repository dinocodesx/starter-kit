{
  "name": "@creator-suite/db-pg",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "prisma generate --schema prisma/schema && tsc -p tsconfig.json",
    "check-types": "prisma generate --schema prisma/schema && tsc -p tsconfig.json",
    "prisma:generate": "prisma generate --schema prisma/schema",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema",
    "prisma:push": "prisma db push --schema prisma/schema",
    "prisma:studio": "prisma studio --schema prisma/schema",
    "db:seed": "tsx src/seed.ts",
    "test": "node --test dist/__tests__/*.js"
  },
  "prisma": {
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@creator-suite/types": "workspace:*",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "dotenv": "^16.4.7",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "prisma": "^7.0.0",
    "tsx": "^4.22.3"
  }
}
